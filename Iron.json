          "sets": 4,
          "rpe": 9,
          "reps": "15–20",
          "tempo": "2-0-2-2",
          "rest": 60,
          "cues": ["Lead with elbows, not wrists", "Pinkies slightly up at peak", "No torso swing — strict control"],
          "targetMuscles": ["shoulders"],
          "videoRef": "cable-lateral",
          "notes": "Use cable for constant tension. Keep contraction at top."
