        {
          "id": "bb-6",
          "exercise": "Rope Pushdown",
          "sets": 3,
          "rpe": 7,
          "reps": "15–20",
          "tempo": "2-0-2-1",
          "rest": 60,
          "cues": ["Flare the rope at bottom", "Elbows pinned to sides", "Full extension at bottom"],
          "targetMuscles": ["triceps"],
          "videoRef": "rope-pushdown",
          "notes": "Finisher movement. Go lighter, feel every rep."
        }
      ]
    },
