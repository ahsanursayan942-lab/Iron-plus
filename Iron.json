        {
          "id": "bb-5",
          "exercise": "Machine Shoulder Press",
          "sets": 3,
          "rpe": 8,
          "reps": "10–12",
          "tempo": "2-1-2-0",
          "rest": 90,
          "cues": ["Seat height: handles at shoulder level", "Push straight up, not forward", "Avoid shrugging at top"],
          "targetMuscles": ["shoulders", "triceps"],
          "videoRef": "machine-shoulder",
          "notes": "Machine allows safer higher-rep work on shoulders."
